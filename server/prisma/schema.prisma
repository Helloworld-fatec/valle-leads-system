generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["schemaEngineDriverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Stores {
  id                 String   @id @default(uuid())
  name               String
  address            String?
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id String?
  updated_by_user_id String?
  teams              Teams[]

  @@map("stores")
}

model Teams {
  id                 String         @id @default(uuid())
  store_id           String
  name               String
  is_active          Boolean        @default(true)
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  created_by_user_id String?
  updated_by_user_id String?
  leads              Leads[]
  negotiations       Negotiations[]
  store              Stores         @relation(fields: [store_id], references: [id])
  user_teams         UserTeams[]

  @@index([store_id])
  @@index([created_at])
  @@map("teams")
}

model Users {
  id                    String         @id @default(uuid())
  email                 String         @unique
  password_hash         String
  name                  String
  role                  String         @default("ATTENDANT")
  is_active             Boolean        @default(true)
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt
  created_by_user_id    String?
  updated_by_user_id    String?
  address_city          String?
  address_complement    String?
  address_neighborhood  String?
  address_number        String?
  address_state         String?
  address_street        String?
  address_zip           String?
  phone_1_ddd           String?
  phone_1_number        String?
  phone_2_ddd           String?
  phone_2_number        String?
  leads_assigned        Leads[]        @relation("AttendantLeads")
  negotiations_assigned Negotiations[] @relation("AttendantNegotiations")
  logs                  SystemLogs[]
  user_teams            UserTeams[]

  @@index([created_at])
  @@map("users")
}

model UserTeams {
  id                 String   @id @default(uuid())
  user_id            String
  team_id            String
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id String?
  is_active          Boolean  @default(true)
  team               Teams    @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user               Users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, team_id])
  @@index([user_id])
  @@index([team_id])
  @@map("user_teams")
}

model Customers {
  id                   String         @id @default(uuid())
  name                 String
  email                String?        @unique
  cpf                  String?        @unique
  phone                String         @unique
  is_active            Boolean        @default(false)
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt
  created_by_user_id   String?
  updated_by_user_id   String?
  address_city         String?
  address_complement   String?
  address_neighborhood String?
  address_number       String?
  address_state        String?
  address_street       String?
  address_zip          String?
  leads                Leads[]
  negotiations         Negotiations[]

  @@index([created_at])
  @@map("customers")
}

model InterestItems {
  id                 String   @id @default(uuid())
  reference_code     String?  @unique
  description        String
  value              Decimal? @db.Decimal(15, 2)
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id String?
  updated_by_user_id String?
  leads              Leads[]

  @@index([reference_code])
  @@index([created_at])
  @@map("interest_items")
}

model Leads {
  id                 String                    @id @default(uuid())
  source             String?
  status             String                    @default("new")
  is_active          Boolean                   @default(true)
  customer_id        String?
  team_id            String?
  attendant_id       String?
  created_at         DateTime                  @default(now())
  updated_at         DateTime                  @updatedAt
  created_by_user_id String?
  updated_by_user_id String?
  interest_item_id   String?
  attendant          Users?                    @relation("AttendantLeads", fields: [attendant_id], references: [id])
  customers          Customers?                @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  interest_item      InterestItems?            @relation(fields: [interest_item_id], references: [id])
  teams              Teams?                    @relation(fields: [team_id], references: [id], onDelete: Restrict)
  importance_history NegotiationImportance[]   @relation("LeadImportanceHistory")
  stage_history      NegotiationStageHistory[] @relation("LeadStageHistory")
  status_history     NegotiationStatus[]       @relation("LeadStatusHistory")
  negotiations       Negotiations[]

  @@index([team_id])
  @@index([attendant_id])
  @@index([customer_id])
  @@index([interest_item_id])
  @@index([status])
  @@index([created_at])
  @@map("leads")
}

model Negotiations {
  id                 String                    @id @default(uuid())
  team_id            String
  lead_id            String
  created_at         DateTime                  @default(now())
  updated_at         DateTime                  @updatedAt
  created_by_user_id String?
  updated_by_user_id String?
  attendant_id       String?
  customer_id        String
  importance_history NegotiationImportance[]
  stage_history      NegotiationStageHistory[]
  status_history     NegotiationStatus[]
  attendant          Users?                    @relation("AttendantNegotiations", fields: [attendant_id], references: [id])
  customers          Customers                 @relation(fields: [customer_id], references: [id])
  leads              Leads                     @relation(fields: [lead_id], references: [id])
  teams              Teams                     @relation(fields: [team_id], references: [id])

  @@index([team_id])
  @@index([lead_id])
  @@index([customer_id])
  @@index([attendant_id])
  @@index([created_at])
  @@map("negotiations")
}

model NegotiationStatus {
  id                 String       @id @default(uuid())
  status_negotiation String       @default("new")
  notes              String?
  negotiation_id     String
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  created_by_user_id String?
  updated_by_user_id String?
  lead_id            String
  leads              Leads        @relation("LeadStatusHistory", fields: [lead_id], references: [id], onDelete: Cascade)
  negotiations       Negotiations @relation(fields: [negotiation_id], references: [id], onDelete: Cascade)

  @@index([negotiation_id])
  @@index([lead_id])
  @@index([created_at])
  @@map("negotiation_status_history")
}

model NegotiationStageHistory {
  id                 String       @id @default(uuid())
  notes              String?
  negotiation_id     String
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  created_by_user_id String?
  updated_by_user_id String?
  lead_id            String
  new_stage          String
  old_stage          String?
  leads              Leads        @relation("LeadStageHistory", fields: [lead_id], references: [id], onDelete: Cascade)
  negotiations       Negotiations @relation(fields: [negotiation_id], references: [id], onDelete: Cascade)

  @@index([negotiation_id])
  @@index([lead_id])
  @@index([created_at])
  @@map("negotiation_stage_history")
}

model NegotiationImportance {
  id                 String       @id @default(uuid())
  importance         String       @default("morno")
  notes              String?
  negotiation_id     String
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  created_by_user_id String?
  updated_by_user_id String?
  lead_id            String
  leads              Leads        @relation("LeadImportanceHistory", fields: [lead_id], references: [id], onDelete: Cascade)
  negotiations       Negotiations @relation(fields: [negotiation_id], references: [id], onDelete: Cascade)

  @@index([negotiation_id])
  @@index([lead_id])
  @@index([created_at])
  @@map("negotiation_importance_history")
}

model SystemLogs {
  id                 String   @id @default(uuid())
  action             String
  module             String
  description        String?
  ip_address         String?
  user_id            String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id String?
  users              Users?   @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([module])
  @@index([created_at])
  @@map("system_logs")
}
